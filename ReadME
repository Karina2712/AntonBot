📈 Метрики
Метрика	API	Пример
Пользователи	len(data/stats.json)	47
Записи	Booking.select().count()	12
Поиски	UserSearchHistory.count()	89
Состояний	len(StateManager._states)	3
🧪 Тестирование API
python
# Тест 1: Поиск тату
from src.handlers.client import process_tattoo_idea
process_tattoo_idea(bot, 123456, "волк", "предплечье")

# Тест 2: Статистика
from src.services.stats import get_stats
assert "📊 СТАТИСТИКА" in get_stats()

# Тест 3: Состояние
from src.utils.state_manager import StateManager
StateManager.set(123, 'test', {'data': 'test'})
assert StateManager.get(123)['state'] == 'test'
